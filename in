<header>
    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="#">FitLife Studio</a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#menu">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="menu">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="#inicio">Inicio</a></li>
                    <li class="nav-item"><a class="nav-link" href="#servicios">Servicios</a></li>
                    <li class="nav-item"><a class="nav-link" href="#beneficios">Beneficios</a></li>
                    <li class="nav-item"><a class="nav-link" href="#contacto">Contacto</a></li>
                </ul>
            </div>
        </div>
    </nav>
</header>

<!-- MAIN -->
<main>

    <!-- SECCIÓN BIENVENIDA -->
    <section id="inicio" class="hero text-center text-light d-flex align-items-center">
        <div class="container">
            <h1>Transforma tu cuerpo, mejora tu vida</h1>
            <p>Entrenamiento funcional, clases grupales y planes personalizados.</p>
            <button class="btn btn-primary btn-lg">Únete ahora</button>
        </div>
    </section>

    <!-- SERVICIOS -->
    <section id="servicios" class="container py-5">
        <h2 class="text-center mb-4">Nuestros Servicios</h2>
        <div class="row">

            <div class="col-12 col-md-6 col-lg-4 mb-4">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">Entrenamiento Funcional</h5>
                        <p class="card-text">Rutinas dinámicas para mejorar fuerza, resistencia y movilidad.</p>
                        <button class="btn btn-outline-primary">Ver más</button>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-6 col-lg-4 mb-4">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">Clases Grupales</h5>
                        <p class="card-text">Entrena en grupo con instructores certificados.</p>
                        <button class="btn btn-outline-primary">Ver más</button>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-6 col-lg-4 mb-4">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">Planes Personalizados</h5>
                        <p class="card-text">Programas adaptados a tus objetivos y condición física.</p>
                        <button class="btn btn-outline-primary">Ver más</button>
                    </div>
                </div>
            </div>

        </div>
    </section>

    <!-- BENEFICIOS / TESTIMONIOS -->
    <section id="beneficios" class="bg-light py-5">
        <div class="container">
            <h2 class="text-center mb-4">Beneficios</h2>

            <div class="accordion" id="accordionExample">

                <div class="accordion-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button" data-bs-toggle="collapse" data-bs-target="#beneficio1">
                            Mejora tu salud
                        </button>
                    </h2>
                    <div id="beneficio1" class="accordion-collapse collapse show">
                        <div class="accordion-body">
                            Reduce el estrés y mejora tu condición física general.
                        </div>
                    </div>
                </div>

                <div class="accordion-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button collapsed" data-bs-toggle="collapse" data-bs-target="#beneficio2">
                            Ambiente motivador
                        </button>
                    </h2>
                    <div id="beneficio2" class="accordion-collapse collapse">
                        <div class="accordion-body">
                            Entrena con personas que comparten tus metas.
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </section>

    <!-- FORMULARIO -->
    <section id="contacto" class="container py-5">
        <h2 class="text-center mb-4">Contáctanos</h2>

        <form>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <input type="text" class="form-control" placeholder="Nombre">
                </div>
                <div class="col-md-6 mb-3">
                    <input type="email" class="form-control" placeholder="Correo">
                </div>
            </div>

            <div class="mb-3">
                <textarea class="form-control" rows="4" placeholder="Mensaje"></textarea>
            </div>

            <button class="btn btn-success">Enviar</button>
        </form>
    </section>

</main>

<!-- FOOTER -->
<footer class="bg-dark text-light text-center py-3">
    <p>&copy; 2026 FitLife Studio | Síguenos en redes sociales</p>
</footer>

